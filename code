# =============================
# basic helpers
# =============================
def compute_acf_at_lag(x: np.ndarray, lag: int) -> float:
    x = np.asarray(x, dtype=float)
    if len(x) <= lag + 1:
        return np.nan
    x = x - np.nanmean(x)
    s = np.nanstd(x)
    if s == 0 or np.isnan(s):
        return np.nan
    return float(np.corrcoef(x[:-lag], x[lag:])[0, 1])


def compute_ac1(x: np.ndarray) -> float:
    return compute_acf_at_lag(x, 1)


def compute_lowfreq_fraction(x: np.ndarray) -> float:
    x = np.asarray(x, dtype=float)
    if len(x) < 8:
        return np.nan

    x = x - np.nanmean(x)
    p = np.abs(np.fft.rfft(x)) ** 2

    if len(p) <= 2:
        return np.nan

    p = p[1:]  # remove zero frequency
    total = np.nansum(p)

    if total <= 0 or np.isnan(total):
        return np.nan

    n_low = max(1, len(p) // 4)
    return float(np.nansum(p[:n_low]) / total)


def fit_ar1_phi_sigma(x: np.ndarray):
    x = np.asarray(x, dtype=float)
    if len(x) < 4:
        return np.nan, np.nan, np.nan

    x = x - np.nanmean(x)
    denom = np.nansum(x[:-1] ** 2)

    if denom <= 0 or np.isnan(denom):
        return np.nan, np.nan, np.nan

    phi = float(np.nansum(x[:-1] * x[1:]) / denom)
    resid = x[1:] - phi * x[:-1]

    sigma_eps = float(np.nanstd(resid, ddof=1)) if len(resid) > 1 else np.nan
    signal_std = float(np.nanstd(x, ddof=1)) if len(x) > 1 else np.nan

    return phi, sigma_eps, signal_std


def downsample_signal(x: np.ndarray, sfreq: float, target_fs: float) -> np.ndarray:
    if np.isclose(sfreq, target_fs):
        return x

    from math import gcd

    sf_int = int(round(sfreq))
    tf_int = int(round(target_fs))
    g = gcd(sf_int, tf_int)

    up = tf_int // g
    down = sf_int // g

    return resample_poly(x, up=up, down=down, axis=-1)


def get_eeg_channel_names(raw: mne.io.BaseRaw) -> list[str]:
    picks = mne.pick_types(
        raw.info,
        eeg=True,
        eog=False,
        ecg=False,
        emg=False,
        misc=False,
        stim=False,
        exclude=[],
    )
    return [raw.ch_names[p] for p in picks]


def read_participants() -> pd.DataFrame:
    p = RAW_DATA_DIR / "participants.tsv"
    df = pd.read_csv(p, sep="\t")

    if "SCID_notes" in df.columns:
        df = df[
            ~df["SCID_notes"]
            .astype(str)
            .str.contains("INVALID PARTICIPANT", case=False, na=False)
        ].copy()

    return df


